# SITL parameter baseline — KNOWN-GOOD reference config.
#
# Anchored to 2026-05-02 hover tests on the corrected 1.365 kg / T/W 1.82
# build (post per-component mass audit + new aero model). Rate gains
# 0.03 P/I, 0.006 D produced the best result so far: drone airborne >50 s
# with bounded ±20° oscillation. NOT a clean hover yet — AUTOTUNE is the
# next step, not more manual tuning. Older 0.10 P/I gains were tuned for
# the obsolete 1.96 kg / 4:1 T/W build and are too hot for the current
# dynamics. See inline tuning-history comment near the ATC_RAT_* block.
#
# Promote a new config to this file ONLY after a flight is verified to fly
# stably. To revert: cp sitl_params_best.parm sitl_params_test.parm.
#
# Notes inline mark which lines are SITL-only vs which transfer to the real
# F450 — pay attention before flashing onto hardware.

SCHED_LOOP_RATE 100
FRAME_CLASS 1
FRAME_TYPE 1
ARMING_MAGTHRESH 0

# SITL-ONLY: skip GPS (bit 3 = 8) + INS (bit 4 = 16) pre-arm checks. 4.8-dev
# flags SITL's JSON-backend GPS as "unhealthy" and its gyro-rate as too low
# relative to SCHED_LOOP_RATE even though both are fine for sim.
ARMING_SKIPCHK 24

# SITL-ONLY: cleaner simulated GPS so Loiter/Auto pre-arm passes without
# waiting minutes. Names changed to SIM_GPS1_* in ArduCopter 4.5+. The old
# SIM_GPS1_HDOP param was REMOVED in 4.8-dev (replaced by SIM_GPS1_ACC,
# default 0.3 m, already small enough — no override needed).
SIM_GPS1_NUMSATS 18

# Relax the hard GPS-quality threshold that gates Loiter/Auto arming.
GPS_HDOP_GOOD 230

# Hover-throttle prior — real F450 3S/920kv setups converge here.
MOT_THST_HOVER 0.55

# Cap guided takeoff climb rate to 1.5 m/s. The bridge's CoM offset will
# be addressed sim-side (option c — apply thrust at composite CoM in
# Nvidia_SITL_connecter.py); this param is back to a normal F450 climb rate.
# 4.8-dev rename: WPNAV_* -> WP_*, AND units changed cm/s -> m/s.
WP_SPD_UP 1.5
WP_ACC_Z 1.0
PILOT_SPD_UP 1.5
PILOT_ACC_Z 1.0

# Safety: cap lean angle at 30°.
# 4.8-dev rename: ANGLE_MAX (centidegrees) -> ATC_ANGLE_MAX (degrees).
ATC_ANGLE_MAX 30

# Cap the POSITION controller's commanded lean angle at 5°. Default is 0
# (= use ATC_ANGLE_MAX 30°), which lets the position controller demand huge
# attitude swings from any small EKF velocity error during the post-bridge-
# fix takeoff. With option (c) (Nvidia_SITL_connecter.py applies thrust at
# composite CoM), the drone is neutrally stable at hover; tiny perturbations
# at liftoff get amplified into ±25° pitch swings as the position controller
# chases EKF noise. Capping at 5° prevents that runaway. Once airborne and
# settled, EKF velocity stabilizes and 5° is plenty for normal position-hold.
PSC_ANGLE_MAX 5

# Raise auto-disarm timeout to 60s for mission-script timing.
DISARM_DELAY 60

# SITL-ONLY: terrain DB is incomplete for Yerevan and returns bogus offsets.
# 4.8-dev rename: WPNAV_RFND_USE -> WP_RFND_USE (default is 1, we want 0).
TERRAIN_ENABLE 0
WP_RFND_USE 0

# Rate gains — back to the best-known baseline for the post-bridge-fix
# drone. Tuning history exhausted (2026-05-02):
#   - 0.10 P/I, default D, default ANG: pitch rate hit ±396°/s, drone
#     barely lifted off — gains way too hot for the lighter / smaller-arm
#     dynamics, even with the bridge fix in place.
#   - 0.03 P/I, 0.006 D, default ANG: BEST so far. Drone airborne >50 s,
#     bounded oscillation ±20°, eventual slow degradation. This is where
#     AUTOTUNE should start from.
#   - Various intermediates (D=0.008, 0.010, ATC_ANG=3.0, 2.0) all moved
#     us away from this baseline.
# Returning to the best, full stop. AUTOTUNE is the next step, not more
# manual tuning.
ATC_RAT_RLL_P 0.03
ATC_RAT_RLL_I 0.03
ATC_RAT_PIT_P 0.03
ATC_RAT_PIT_I 0.03
ATC_RAT_RLL_D 0.006
ATC_RAT_PIT_D 0.006
# ATC_ANG_*_P left at firmware default (4.5).

# YAW rate gains — defaults 0.18 P / 0.018 I were never tuned for this build.
# Logs from 2026-05-02 show yaw drifts 50–180° during every flight even when
# roll/pitch stay bounded; gyro_z oscillates ±130°/s (rate-loop overshoot,
# not steady disturbance — static-arm test confirmed no external yaw torque).
# Mirror the RLL/PIT scaling: default 0.135 → 0.03 (4.5× reduction), so
# 0.18 / 4.5 ≈ 0.04. Round up to 0.05 as a conservative starting point.
# Keep P:I = 1:1 (matches what worked for RLL/PIT) and YAW_D at default 0.
# Yaw rate gains revised 2026-05-02 evening: dataflash analysis showed
# YDes (commanded rate target) at ±75°/s but actual yaw rate Y reaching
# ±130°/s — i.e., a real torque disturbance (likely roll+pitch → yaw
# coupling via differential prop reaction) that the rate loop couldn't
# fight at P=0.05. Doubling P to 0.10 doubles corrective torque per unit
# of rate error. Adding D=0.005 damps overshoot from the higher P. Still
# below firmware default 0.18 P / 0 D — conservative compromise.
ATC_RAT_YAW_P 0.10
ATC_RAT_YAW_I 0.10
ATC_RAT_YAW_D 0.005

# YAW angle controller (outer loop) — default 4.5 was never tuned for this
# build either. With composite-CoM bridge fix + PSC_ANGLE_MAX 5, roll/pitch
# are now stable. Yaw still oscillated ±30°+ at 2.0; AUTOTUNE failed to
# advance because yaw spinning ±100°/s contaminated every roll/pitch twitch.
# Halve again: 1.0 ≈ default 4.5 / 4.5 (matching the rate-loop reduction
# from default 0.18 -> 0.05 ≈ 3.6×, rounded for safety). If 1.0 still
# oscillates, fall back to ATC_RATE_Y_MAX 30 (hard rate-target cap).
# Roll/pitch ATC_ANG_*_P stay at default (4.5) since they're working.
ATC_ANG_YAW_P 1.0

# AUTOTUNE setup, used after we have a stable hover from these baseline gains.
# AUTOTUNE_AXES bitmask: 1=roll, 2=pitch, 4=yaw (sum = which axes to tune).
# Currently 3 = roll+pitch only — yaw is still oscillating ±100°/s and
# would tumble the drone during yaw twitches. After roll/pitch tune,
# fix yaw manually (lower ATC_ANG_YAW_P further) then re-autotune with
# AUTOTUNE_AXES 4 to tune yaw alone.
AUTOTUNE_AXES 3
AUTOTUNE_AGGR 0.075

# SITL-ONLY: disable EKF auto-action on failsafe. SITL's JSON-backend GPS
# reports vel_acc=0, making the EKF variance check hyper-sensitive.
FS_EKF_ACTION 0
FS_GCS_ENABLE 0

# SITL-ONLY: relax EK3_GPS_CHECK to NSats+HDoP only (bits 0-1, value 3).
# Default 31 includes a speed_err check that the JSON GPS can't pass.
EK3_GPS_CHECK 3

# GPS glitch radius: 100m (default 25m is too tight for sim transients).
EK3_GLITCH_RAD 100

# SITL-ONLY: clean baro to avoid spurious vz in GLOBAL_POSITION_INT at rest.
SIM_BARO_RND 0.01
